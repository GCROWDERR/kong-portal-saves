---
title: "Example Page Banner"
description: "Parameterized hero CTA row. Override bannerTitle, bannerDescription, primaryTo, primaryLabel, secondaryTo, secondaryLabel, secondaryAppearance, secondaryBorder, secondaryBackground, bannerMargin via ::snippet data."
bannerTitle: "Explore our APIs"
bannerDescription: "Connect, create, and innovate with our easy-to-use APIs."
bannerMargin: "0"
primaryTo: "/apis"
primaryLabel: "Start building"
secondaryTo: "/guides"
secondaryLabel: "Read guides"
secondaryAppearance: "secondary"
secondaryBorder: "1px solid #d5e3fd"
secondaryBackground: "#fff"
---

::page-hero
---
full-width: true
title-tag: "h2"
text-align: "center"
title-font-size: "36px"
title-line-height: "40px"
description-font-weight: "400"
description-font-size: "22px"
description-line-height: "30px"
background-color: "var(--kui-color-background-primary-weakest)"
padding: "20px 0px"
:margin: snippet.bannerMargin
---
#title
{{ $doc.snippet.bannerTitle || 'Explore our APIs' }}

#description
{{ $doc.snippet.bannerDescription || 'Connect, create, and innovate with our easy-to-use APIs.' }}

#actions
  ::container
  ---
  display: "flex"
  flex-direction: "row"
  flex-wrap: "wrap"
  gap: "12px"
  justify-content: "center"
  align-items: "center"
  ---
    :::button
    ---
    :to: snippet.primaryTo
    appearance: "primary"
    size: "large"
    ---
    {{ $doc.snippet.primaryLabel || 'Start building' }}
    :::

    :::button
    ---
    :to: snippet.secondaryTo
    :appearance: snippet.secondaryAppearance
    size: "large"
    :border: snippet.secondaryBorder
    :background-color: snippet.secondaryBackground
    ---
    {{ $doc.snippet.secondaryLabel || 'Read guides' }}
    :::
  ::
::
