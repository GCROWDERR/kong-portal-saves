  Guides FAQ uses this snippet as a whole (:::snippet name: br-accordion). Edit the br-accordion-panel blocks below for Q&A copy; duplicate a panel block to add a row.
  Optional data.expanded: true for default-open. For markdown bodies, paste ::accordion-panel with #header / #default inside this group instead.
-->

::accordion-group
---
gap: "0"
multiple: true
panel-props:
  border: "none"
  border-radius: "0"
  background-color: "#fff"
  header-background: "#fff"
  header-color: "#151515"
  header-padding: "20px 16px"
  header-font-size: "18px"
  header-line-height: "1.7"
  header-font-weight: 400
  content-color: "#515260"
  content-background: "#fff"
  content-padding: "4px 16px 24px"
  content-font-size: "16px"
styles: |
  .accordion-panel {
    border-bottom: 1px solid #e2e5ed;
  }

  .accordion-panel:first-child {
    border-top: 1px solid #e2e5ed;
  }

  .accordion-panel button[aria-expanded] {
    letter-spacing: -0.25px;
  }

  .accordion-panel .accordion-panel__content {
    line-height: 1.7;
    letter-spacing: -0.25px;
  }

  .accordion-panel .kui-icon path,
  .accordion-panel .kui-icon svg path {
    fill: #0157ff;
  }

  .accordion-panel .kui-icon {
    width: 24px !important;
    height: 24px !important;
  }
---
